NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/medium_clone
# Generate strong, unique secrets (32+ chars). e.g. `openssl rand -base64 48`
# The server refuses to start in production with a short/placeholder secret.
JWT_SECRET=change_me_use_a_random_48_byte_base64_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_use_a_different_random_48_byte_string
JWT_REFRESH_EXPIRES_IN=30d
CLIENT_URL=http://localhost:5173
# Trusted proxy hops in front of the app (for correct client IP / rate limiting).
# Defaults to 1 in production, 0 in dev. Set to your real hop count behind nginx/Render.
# TRUST_PROXY=1
